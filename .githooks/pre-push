#!/bin/sh
# Full verification gate before any push. A red gate blocks the push, so a broken
# tree cannot reach the remote. Commands run one at a time to respect the Pi memory
# budget. Set BINNACLE_SKIP_PREPUSH=1 only for a deliberate, documented exception.
set -e

if [ "$BINNACLE_SKIP_PREPUSH" = "1" ]; then
  echo "[pre-push] skipped via BINNACLE_SKIP_PREPUSH"
  exit 0
fi

export NODE_OPTIONS="${NODE_OPTIONS:---max-old-space-size=2048}"

# Surface divergent state at the moment of pushing so stray uncommitted changes and
# leftover branches are seen now, not rediscovered later with unknown provenance. This
# is informational and never blocks the push.
DRIFT="$(git status --porcelain)"
if [ -n "$DRIFT" ]; then
  echo "[pre-push] note: uncommitted changes are NOT part of this push:"
  echo "$DRIFT" | sed 's/^/    /'
  echo "[pre-push] commit, discard, or stash them so nothing drifts unnoticed."
fi
STRAY_BRANCHES="$(git for-each-ref --format='%(refname:short)' refs/heads | grep -vx 'main' || true)"
if [ -n "$STRAY_BRANCHES" ]; then
  echo "[pre-push] note: local branches besides main exist; delete merged ones:"
  echo "$STRAY_BRANCHES" | sed 's/^/    /'
fi

echo "[pre-push] biome ci"
biome ci .

echo "[pre-push] dependency-cruiser"
npm run --silent cruise

echo "[pre-push] type-check"
npm run --silent check

echo "[pre-push] unit tests"
npm run --silent test

echo "[pre-push] production build"
NODE_ENV=production npm run --silent build

echo "[pre-push] all gates green"
